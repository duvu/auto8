# DATABASE_URL: PostgreSQL connection string
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME"
API_PORT=4000
SLACK_SIGNING_SECRET="replace-with-slack-signing-secret"
SLACK_ALLOWED_WORKSPACE_IDS="W_AUTO8_DEMO"
SLACK_BOT_TOKEN="xoxb-replace-with-slack-bot-token"
GMAIL_CONNECTOR_SECRET="replace-with-a-strong-random-secret"
GMAIL_CLIENT_ID="replace-with-google-oauth-client-id"
GMAIL_CLIENT_SECRET="replace-with-google-oauth-client-secret"
GMAIL_REFRESH_TOKEN="replace-with-oauth-refresh-token"
GMAIL_SEARCH_QUERY="subject:RFQ is:unread"
GMAIL_MAX_RESULTS="20"
GMAIL_CRON_SCHEDULE="0 * * * *"
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Set to true to enable AI-generated email subjects and body intros for quote emails (opt-in, defaults to false)
QUOTE_EMAIL_AI=false
# RFQ_CLASSIFICATION_THRESHOLD: float 0-1, default 0.7. Messages scored below this are marked isRfq=false.
RFQ_CLASSIFICATION_THRESHOLD=0.7
# JWT_SECRET: required for JWT auth (use a long random string in production)
JWT_SECRET=replace-with-a-long-random-secret
# JWT_ACCESS_EXPIRES_IN: short-lived access token expiry (default 15m)
JWT_ACCESS_EXPIRES_IN=15m
# JWT_REFRESH_EXPIRES_IN: long-lived refresh token expiry (default 7d)
JWT_REFRESH_EXPIRES_IN=7d
# JWT_EXPIRES_IN: legacy fallback (kept for compatibility)
JWT_EXPIRES_IN=24h
# ALLOWED_ORIGINS: comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:3000
# SMTP_SECURE: set to false for dev SMTP servers (MailHog etc), true for production
SMTP_SECURE=true
# FRONTEND_URL: base URL for password reset links in emails
FRONTEND_URL=http://localhost:3000
# ATTACHMENT_STORAGE_PATH: local directory for storing email attachments (default: ./attachments)
ATTACHMENT_STORAGE_PATH=./attachments
# GOOGLE_SHEET_ID: Google Sheets spreadsheet ID for quote export (optional)
GOOGLE_SHEET_ID=
# GOOGLE_SERVICE_ACCOUNT_KEY: JSON string of Google service account key (optional)
GOOGLE_SERVICE_ACCOUNT_KEY=

# Connector Registry
CONNECTOR_AUTO_DISABLE_THRESHOLD=5
