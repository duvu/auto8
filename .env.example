# DATABASE_URL: PostgreSQL connection string
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME"
API_PORT=4000
WEB_PORT=3000
NEXT_PUBLIC_API_BASE_URL="http://localhost:4000"
# JWT authentication
JWT_SECRET=replace-with-a-long-random-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_EXPIRES_IN=24h
# CORS allowed origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000
# SMTP TLS: set to false for dev SMTP (MailHog etc)
SMTP_SECURE=true
# FRONTEND_URL: base URL for password reset emails
FRONTEND_URL=http://localhost:3000
# AI / LLM
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
SLACK_BOT_TOKEN=replace-with-slack-bot-token
SLACK_SIGNING_SECRET="replace-with-slack-signing-secret"
SLACK_ALLOWED_WORKSPACE_IDS="W_AUTO8_DEMO"
GMAIL_CONNECTOR_SECRET="replace-with-a-strong-random-secret"
GMAIL_CLIENT_ID="replace-with-google-oauth-client-id"
GMAIL_CLIENT_SECRET="replace-with-google-oauth-client-secret"
GMAIL_REFRESH_TOKEN="replace-with-oauth-refresh-token"
GMAIL_SEARCH_QUERY="subject:RFQ is:unread"
GMAIL_MAX_RESULTS="20"
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="quotes@example.com"
SMTP_PASS="replace-with-smtp-password"
QUOTE_EMAIL_FROM="quotes@example.com"
