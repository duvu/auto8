generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  quote_operator
  sales_approver
  admin
}

enum QuoteStatus {
  draft
  pending_approval
  approved
  revised
}

enum RfqWorkflowState {
  new
  draft
  pending_approval
  approved
}

enum RfqSourceType {
  email
  slack
  outlook
  whatsapp
  telegram
  zalo
}

model User {
  id                   String               @id @default(cuid())
  email                String               @unique
  name                 String
  role                 UserRole
  passwordHash         String               @default("")
  isActive             Boolean              @default(true)
  createdAt            DateTime             @default(now())
  quotesCreated        Quote[]              @relation("QuoteCreatedBy")
  quotesApproved       Quote[]              @relation("QuoteApprovedBy")
  statusEvents         QuoteStatusEvent[]
  emailSends           QuoteEmailSend[]
  refreshTokens        RefreshToken[]
  passwordResetTokens  PasswordResetToken[]
  templatesCreated     QuoteTemplate[]      @relation("TemplateCreatedBy")
  assignedRfqs         Rfq[]                @relation("RfqAssignedTo")
}

model RfqIntake {
  id                 String        @id @default(cuid())
  sourceType         RfqSourceType
  sourceLabel        String
  senderEmail        String?
  senderName         String?
  subject            String
  body               String
  receivedAt         DateTime
  rawPayload  String
  slackWorkspaceId   String?
  slackWorkspaceName String?
  slackChannelId     String?
  slackChannelName   String?
  slackSubmitterId   String?
  slackSubmitterName String?
  slackSubmitterEmail String?
  slackMessageId     String?       @unique
  gmailMessageId     String?       @unique
  gmailThreadId      String?
  outlookMessageId   String?
  isRfq              Boolean       @default(true)
  classificationScore Float?
  classificationReason String?
  rfqPipelineStatus  String        @default("new")
  attachmentContent  String?
  isReply            Boolean       @default(false)
  replyToRfqId       String?
  replyToRfq         Rfq?          @relation("RfqReplies", fields: [replyToRfqId], references: [id])
  connectorId        String?
  connector          Connector?    @relation(fields: [connectorId], references: [id])
  createdAt          DateTime      @default(now())
  rfq                Rfq?
  attachments        RfqAttachment[]
}

model Rfq {
  id                String             @id @default(cuid())
  reference         String             @unique
  workflowState     RfqWorkflowState   @default(new)
  assignedToId      String?
  assignedTo        User?              @relation("RfqAssignedTo", fields: [assignedToId], references: [id])
  expectedResponseBy DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  intakeId          String             @unique
  intake            RfqIntake          @relation(fields: [intakeId], references: [id])
  quote             Quote?
  extractedItems    RfqExtractedItem[]
  extractedCustomer RfqExtractedCustomer?
  replyIntakes      RfqIntake[]           @relation("RfqReplies")
}

model RfqExtractedItem {
  id               String         @id @default(cuid())
  rfqId            String
  rfq              Rfq            @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  partNumber       String?
  description      String
  quantity         Float?
  unit             String?
  confidence       Float
  confidenceReason String?
  createdAt        DateTime       @default(now())
  matches          RfqItemMatch[]
}

model Quote {
  id              String             @id @default(cuid())
  customerName    String
  customerCompany String
  notes           String?
  discount        Float              @default(0)
  tax             Float              @default(0)
  grandTotal      Float?
  currency        String             @default("USD")
  exchangeRate    Float              @default(1.0)
  paymentTerms    String?
  deliveryTerms   String?
  validityDays    Int?
  version         Int                @default(1)
  parentQuoteId   String?
  parentQuote     Quote?             @relation("QuoteRevisions", fields: [parentQuoteId], references: [id])
  revisions       Quote[]            @relation("QuoteRevisions")
  status          QuoteStatus        @default(draft)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  submittedAt     DateTime?
  approvedAt      DateTime?
  rfqId           String             @unique
  rfq             Rfq                @relation(fields: [rfqId], references: [id])
  createdById     String
  createdBy       User               @relation("QuoteCreatedBy", fields: [createdById], references: [id])
  approvedById    String?
  approvedBy      User?              @relation("QuoteApprovedBy", fields: [approvedById], references: [id])
  customerId      String?
  customer        Customer?          @relation(fields: [customerId], references: [id])
  lineItems       QuoteLineItem[]
  statusEvents    QuoteStatusEvent[]
  email           QuoteEmail?
}

model QuoteLineItem {
  id          String   @id @default(cuid())
  description String
  quantity    Int
  unitPrice   Float
  sortOrder   Int
  discount    Float    @default(0)
  subtotal    Float    @default(0)
  productId   String?
  createdAt   DateTime @default(now())
  quoteId     String
  quote       Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  product     Product? @relation(fields: [productId], references: [id])
}

model IngestionRun {
  id             String     @id @default(cuid())
  connectorName  String
  startedAt      DateTime
  finishedAt     DateTime
  imported       Int        @default(0)
  skipped        Int        @default(0)
  failed         Int        @default(0)
  status         String
  errorMessage   String?
  connectorId    String?
  connector      Connector? @relation(fields: [connectorId], references: [id])
  connectorLabel String?
  createdAt      DateTime   @default(now())
}

enum QuoteEmailStatus {
  draft
  sent
  error
}

enum QuoteEmailSendStatus {
  sent
  error
}

model QuoteEmail {
  id             String             @id @default(cuid())
  quoteId        String             @unique
  quote          Quote              @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  subject        String
  body           String
  recipientEmail String
  status         QuoteEmailStatus   @default(draft)
  autoSend       Boolean            @default(false)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  sends          QuoteEmailSend[]
}

model QuoteEmailSend {
  id             String               @id @default(cuid())
  quoteEmailId   String
  quoteEmail     QuoteEmail           @relation(fields: [quoteEmailId], references: [id], onDelete: Cascade)
  sentByUserId   String?
  sentBy         User?                @relation(fields: [sentByUserId], references: [id])
  recipientEmail String
  status         QuoteEmailSendStatus
  errorMessage   String?
  sentAt         DateTime
  createdAt      DateTime             @default(now())
}

model QuoteStatusEvent {
  id        String      @id @default(cuid())
  status    QuoteStatus
  createdAt DateTime    @default(now())
  quoteId   String
  quote     Quote       @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  actorId   String?
  actor     User?       @relation(fields: [actorId], references: [id])
}

model AuditLog {
  id           String   @id @default(cuid())
  actorId      String?
  action       String
  resourceType String
  resourceId   String
  before       Json?
  after        Json?
  createdAt    DateTime @default(now())

  @@index([resourceType, resourceId])
  @@index([actorId])
}

model ApiRequestLog {
  id         String   @id @default(cuid())
  method     String
  path       String
  statusCode Int
  latencyMs  Int
  actorId    String?
  ip         String?
  createdAt  DateTime @default(now())

  @@index([createdAt])
}

model ProductCatalogue {
  id                     String                          @id @default(cuid())
  name                   String
  description            String?
  createdAt              DateTime                        @default(now())
  updatedAt              DateTime                        @updatedAt
  products               Product[]
  enrichmentSuggestions  CatalogueEnrichmentSuggestion[]
}

model Product {
  id                String                        @id @default(cuid())
  catalogueId       String
  catalogue         ProductCatalogue              @relation(fields: [catalogueId], references: [id])
  productCode       String                        @unique
  productName       String
  description       String?
  brand             String?
  unit              String?
  basePrice         Float?
  currency          String                        @default("USD")
  defaultMarkup     Float                         @default(0)
  isActive          Boolean                       @default(true)
  categoryTags      String[]
  embedding         Unsupported("vector(1536)")?
  createdAt         DateTime                      @default(now())
  updatedAt         DateTime                      @updatedAt
  lineItems         QuoteLineItem[]
  matches           RfqItemMatch[]
  templateLineItems QuoteTemplateLineItem[]
}

model CatalogueEnrichmentSuggestion {
  id           String           @id @default(cuid())
  catalogueId  String
  catalogue    ProductCatalogue @relation(fields: [catalogueId], references: [id], onDelete: Cascade)
  productCode  String
  suggestions  Json
  status       String           @default("pending")
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
}

model RfqAttachment {
  id           String    @id @default(cuid())
  rfqIntakeId  String
  rfqIntake    RfqIntake @relation(fields: [rfqIntakeId], references: [id], onDelete: Cascade)
  filename     String
  mimeType     String
  sizeBytes    Int
  storagePath  String
  parsedText   String?
  parseStatus  String    @default("pending")
  createdAt    DateTime  @default(now())
}

model Customer {
  id            String    @id @default(cuid())
  companyName   String
  contactName   String?
  email         String?
  phone         String?
  address       String?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  quotes        Quote[]
  extractedCustomers RfqExtractedCustomer[]
}

model RfqExtractedCustomer {
  id                String    @id @default(cuid())
  rfqId             String    @unique
  rfq               Rfq       @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  customerId        String?
  customer          Customer? @relation(fields: [customerId], references: [id])
  customerCompany   String?
  customerContact   String?
  customerEmail     String?
  customerPhone     String?
  deliveryLocation  String?
  requestedDeadline String?
  notes             String?
  createdAt         DateTime  @default(now())
}

model RfqItemMatch {
  id                   String           @id @default(cuid())
  rfqExtractedItemId   String
  rfqExtractedItem     RfqExtractedItem @relation(fields: [rfqExtractedItemId], references: [id], onDelete: Cascade)
  productId            String?
  product              Product?         @relation(fields: [productId], references: [id])
  score                Float
  status               String           @default("pending")
  overrideDescription  String?
  overrideUnitPrice    Float?
  createdAt            DateTime         @default(now())
}

model BackgroundJob {
  id           String    @id @default(cuid())
  type         String
  status       String    @default("pending")
  payload      String    @default("{}")
  attempts     Int       @default(0)
  maxAttempts  Int       @default(3)
  errorMessage String?
  nextRunAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model RefreshToken {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String    @unique
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}

model LlmSetting {
  id        String   @id @default("default")
  provider  String   @default("openai")
  apiKey    String   @default("")
  model     String   @default("gpt-4o-mini")
  baseUrl   String?
  updatedAt DateTime @updatedAt
}

model Connector {
  id             String         @id @default(cuid())
  type           String
  label          String
  credentialsJson String        @default("{}")
  isEnabled      Boolean        @default(true)
  lastSyncAt     DateTime?
  lastError      String?
  failureCount   Int            @default(0)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  rfqIntakes     RfqIntake[]
  ingestionRuns  IngestionRun[]
}

model QuoteTemplate {
  id            String                  @id @default(cuid())
  name          String
  description   String?
  headerNotes   String?
  paymentTerms  String?
  deliveryTerms String?
  validityDays  Int?
  currency      String                  @default("USD")
  createdById   String
  createdBy     User                    @relation("TemplateCreatedBy", fields: [createdById], references: [id])
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt
  lineItems     QuoteTemplateLineItem[]
}

model QuoteTemplateLineItem {
  id          String         @id @default(cuid())
  templateId  String
  template    QuoteTemplate  @relation(fields: [templateId], references: [id], onDelete: Cascade)
  description String
  quantity    Int
  unitPrice   Float          @default(0)
  sortOrder   Int
  productId   String?
  product     Product?       @relation(fields: [productId], references: [id], onDelete: SetNull)
  createdAt   DateTime       @default(now())
}

model SlaConfig {
  id                    String   @id @default("default")
  defaultResponseHours  Int      @default(24)
  warningThresholdHours Int      @default(4)
  updatedAt             DateTime @updatedAt
}

model WebhookEndpoint {
  id         String            @id @default(cuid())
  url        String
  secret     String
  events     String[]
  isEnabled  Boolean           @default(true)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  deliveries WebhookDelivery[]
}

model WebhookDelivery {
  id             String           @id @default(cuid())
  endpointId     String
  endpoint       WebhookEndpoint  @relation(fields: [endpointId], references: [id], onDelete: Cascade)
  event          String
  payload        Json
  status         String           @default("pending")
  responseStatus Int?
  lastError      String?
  attemptCount   Int              @default(0)
  deliveredAt    DateTime?
  createdAt      DateTime         @default(now())
}
